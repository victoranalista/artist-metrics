    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.8",
