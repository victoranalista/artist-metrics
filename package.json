{
  "name": "artist-metrics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "shorts:setup-ig": "tsx scripts/shorts-automation/setup-instagram.ts",
    "shorts:setup-yt": "tsx scripts/shorts-automation/setup-youtube.ts",
    "shorts:run": "tsx scripts/shorts-automation/run.ts",
    "shorts:dry-run": "tsx scripts/shorts-automation/run.ts --dry-run",
    "shorts:week": "tsx scripts/shorts-automation/run.ts --days 7",
    "shorts:month": "tsx scripts/shorts-automation/run.ts --days 30",
    "shorts:batch": "tsx scripts/shorts-automation/run-batch.ts",
    "shorts:batch:dry": "tsx scripts/shorts-automation/run-batch.ts --dry-run",
    "shorts:status": "tsx scripts/shorts-automation/run-batch.ts --status",
    "shorts:scheduler": "tsx scripts/shorts-automation/scheduler.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines"
    ]
  },
  "dependencies": {
